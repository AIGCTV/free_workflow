      "properties": {
        "css": "<style>\r\n  /* 按钮容器的布局 */\r\n  .hotZone {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    gap: 3500px;\r\n    padding: 20px;\r\n    justify-content: center;\r\n    background: transparent;\r\n  }\r\n  \r\n  /* 单个按钮的悬停动画 */\r\n  .buttonWrapper {\r\n    display: inline-block;\r\n    transition: all 0.3s ease;\r\n  }\r\n  \r\n  /* 按钮的主要样式（渐变、描边、圆角等） */\r\n  .customButton {\r\n    padding: 12px 28px;\r\n    border-radius: 50px;\r\n    background: linear-gradient(to bottom, #000000, #2b2b2b, #daa520);\r\n    color: #ffd700;\r\n    font-weight: bold;\r\n    text-align: center;\r\n    box-shadow: \r\n      0 0 0 2px #ffd700,\r\n      0 4px 10px rgba(0, 0, 0, 0.5);\r\n    transition: all 0.3s ease;\r\n    cursor: pointer;\r\n    border: none;\r\n    position: relative;\r\n    overflow: hidden;\r\n  }\r\n  \r\n  /* 悬停时的效果 */\r\n  .customButton:hover {\r\n    transform: translateY(-3px);\r\n    box-shadow: \r\n      0 0 0 2px #ffd700,\r\n      0 8px 20px rgba(218, 165, 32, 0.6);\r\n    background: linear-gradient(to bottom, #000000, #3a3a3a, #ffd700);\r\n  }\r\n  \r\n  /* 点击时的反馈 */\r\n  .customButton:active {\r\n    transform: translateY(1px);\r\n  }\r\n  \r\n  /* 按钮文字样式 */\r\n  .buttonText {\r\n    font-size: 25px;\r\n    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);\r\n    position: relative;\r\n    z-index: 1;\r\n  }\r\n  \r\n  /* 按钮的微光动画 */\r\n  .customButton::after {\r\n    content: \"\";\r\n    position: absolute;\r\n    top: -50%;\r\n    left: -50%;\r\n    width: 200%;\r\n    height: 200%;\r\n    background: linear-gradient(\r\n      to bottom right,\r\n      rgba(255, 215, 0, 0.3),\r\n      rgba(255, 215, 0, 0)\r\n    );\r\n    transform: rotate(30deg);\r\n    opacity: 0;\r\n    transition: opacity 0.5s;\r\n  }\r\n  \r\n  .customButton:hover::after {\r\n    opacity: 1;\r\n  }\r\n</style>",
        "theme": "one_dark"
      },
      "widgets_values": [
        "<div class=\"hotZone\">\n  <a style=\"text-decoration: none;\" href=\"https://v.douyin.com/iSMTvGxp\">\n    <div class=\"buttonWrapper\">\n      <div class=\"customButton\">\n        <span class=\"buttonText\">🐼 抖音教程</span>\n      </div>\n    </div>\n  </a>\n  <a style=\"text-decoration: none;\" href=\"https://space.bilibili.com/3546670109296710\">\n    <div class=\"buttonWrapper\">\n      <div class=\"customButton\">\n        <span class=\"buttonText\">🐼 B站教程</span>\n      </div>\n    </div>\n  </a>\n  <a style=\"text-decoration: none;\" href=\"https://t.zsxq.com/u0BYs\">\n    <div class=\"buttonWrapper\">\n      <div class=\"customButton\">\n        <span class=\"buttonText\">🐼 知识星球</span>\n      </div>\n    </div>\n  </a>\n  <a style=\"text-decoration: none;\" href=\"https://qm.qq.com/q/xW2OiqLVRu\">\n    <div class=\"buttonWrapper\">\n      <div class=\"customButton\">\n        <span class=\"buttonText\">🐼 技术交流</span>\n      </div>\n    </div>\n  </a>\n</div>\n\n<style>\n  /* 按钮容器的布局 */\n  .hotZone {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 35px;\n    padding: 20px;\n    justify-content: center;\n    background: transparent;\n  }\n  \n  /* 单个按钮的悬停动画 */\n  .buttonWrapper {\n    display: inline-block;\n    transition: all 0.3s ease;\n  }\n  \n  /* 按钮的主要样式（渐变、描边、圆角等） */\n  .customButton {\n    padding: 12px 28px;\n    border-radius: 50px;\n    background: linear-gradient(to bottom, #000000, #2b2b2b, #daa520);\n    color: #ffd700;\n    font-weight: bold;\n    text-align: center;\n    box-shadow: \n      0 0 0 2px #ffd700,\n      0 4px 10px rgba(0, 0, 0, 0.5);\n    transition: all 0.3s ease;\n    cursor: pointer;\n    border: none;\n    position: relative;\n    overflow: hidden;\n  }\n  \n  /* 悬停时的效果 */\n  .customButton:hover {\n    transform: translateY(-3px);\n    box-shadow: \n      0 0 0 2px #ffd700,\n      0 8px 20px rgba(218, 165, 32, 0.6);\n    background: linear-gradient(to bottom, #000000, #3a3a3a, #ffd700);\n  }\n  \n  /* 点击时的反馈 */\n  .customButton:active {\n    transform: translateY(1px);\n  }\n  \n  /* 按钮文字样式 */\n  .buttonText {\n    font-size: 25px;\n    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);\n    position: relative;\n    z-index: 1;\n  }\n  \n  /* 按钮的微光动画 */\n  .customButton::after {\n    content: \"\";\n    position: absolute;\n    top: -50%;\n    left: -50%;\n    width: 200%;\n    height: 200%;\n    background: linear-gradient(\n      to bottom right,\n      rgba(255, 215, 0, 0.3),\n      rgba(255, 215, 0, 0)\n    );\n    transform: rotate(30deg);\n    opacity: 0;\n    transition: opacity 0.5s;\n  }\n  \n  .customButton:hover::after {\n    opacity: 1;\n  }\n</style>",
